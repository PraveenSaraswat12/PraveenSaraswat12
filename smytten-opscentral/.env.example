# ── Smytten OpsCentral — environment template ──────────────────────────
# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/smytten_opscentral?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"

# Anthropic — used by the email-intelligence layer (Phase-1 item 6) to parse
# matched emails into structured records. Leave blank to keep that layer off.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Google OAuth — used to connect a Gmail account for the inbox scan (item 6).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/gmail/callback"

# Shared secret required by the cron inbox-scan endpoint (Authorization: Bearer)
CRON_SECRET="change-me"
